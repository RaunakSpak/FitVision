# Supabase PostgreSQL — Project Settings → Database → Connection string → URI
# Put your real password in backend/.env (gitignored), not in this file.

DATABASE_URL=postgresql+psycopg2://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres?sslmode=require

JWT_SECRET_KEY=change-this-to-a-long-random-secret-key-min-32-chars
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# CORS — exact frontend origin(s). Comma-separate for multiple (staging + prod).
# Development:
FRONTEND_URL=http://localhost:3000
# Production example:
# FRONTEND_URL=https://fitvision.vercel.app

# Cookie settings — use secure cookies over HTTPS in production
COOKIE_SECURE=false
COOKIE_SAMESITE=lax

# Production checklist:
# 1. Set JWT_SECRET_KEY to a strong random value
# 2. Set FRONTEND_URL to your deployed frontend URL
# 3. Set COOKIE_SECURE=true when using HTTPS
# 4. Run: alembic upgrade head
# 5. Use Supabase session pooler (IPv4) if direct host fails on Windows
