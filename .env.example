# FitVision AI — Frontend environment
# Copy to .env.local for local development

# Backend API URL (used by Next.js rewrites in next.config.ts)
NEXT_PUBLIC_API_URL=http://localhost:8000

# Production example:
# NEXT_PUBLIC_API_URL=https://api.yourdomain.com

# Deployment notes:
# - Vercel: set NEXT_PUBLIC_API_URL in Project Settings → Environment Variables
# - Ensure backend FRONTEND_URL matches your Vercel domain for CORS + cookies
# - Auth uses httpOnly cookies — no localStorage
